# For local testing only. On GitHub Actions, set these as repository Secrets
# instead (Settings -> Secrets and variables -> Actions) — never commit a real .env.

# Required — Claude API key, used to generate outreach messages
ANTHROPIC_API_KEY=

# Required — Resend API key, used to send the digest email
# Get one at https://resend.com after verifying a sending domain (or subdomain)
RESEND_API_KEY=

# Required — the verified sender address, e.g. "YC GTM Monitor <digest@yc-monitor.yourdomain.com>"
FROM_EMAIL=

# Required — where the daily digest email gets sent
RECIPIENT_EMAIL=
