# For local testing only. On GitHub Actions, set these as repository Secrets
# instead (Settings -> Secrets and variables -> Actions) — never commit a real .env.

# Required — Claude API key, used to generate outreach messages
ANTHROPIC_API_KEY=

# Required — Gmail address the digest is sent from
GMAIL_ADDRESS=

# Required — Gmail App Password (NOT your normal Gmail password)
# Generate one at https://myaccount.google.com/apppasswords (needs 2-Step Verification enabled)
GMAIL_APP_PASSWORD=

# Required — where the daily digest email gets sent
RECIPIENT_EMAIL=
